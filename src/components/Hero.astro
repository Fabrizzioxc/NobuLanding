---
---
<section class="relative bg-nobuBlack text-white pt-32 pb-20 px-6 overflow-hidden">
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="max-w-5xl mx-auto text-center relative z-10">
    <div class="inline-block p-3 mb-8 bg-zinc-900 rounded-2xl border border-zinc-800">
       <img src="/logo-icon.svg" alt="Nobu Icon" class="w-8 h-8" />
    </div>
    
    <h1 class="font-bricolage text-5xl md:text-7xl font-bold tracking-tight mb-6">
      Soluciones web que impulsan <br class="hidden md:block"/> tu negocio
    </h1>
    
    <p class="font-inter text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      Creamos landing pages y sitios web que impulsan tus ventas y procesos digitales.
    </p>

    <button class="bg-nobuBlue hover:bg-blue-600 transition-all px-8 py-4 rounded-full font-bold flex items-center gap-3 mx-auto group">
      Contáctanos 
      <div class="bg-white rounded-full p-1 group-hover:translate-x-1 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-nobuBlue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </div>
    </button>
  </div>
</section>