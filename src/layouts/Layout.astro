---
import '../styles/global.css'
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>Nobu</title>
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    </head>
    <body>
        <main class="w-full">
            <slot />
        </main>
    </body>
</html>

<style is:global>
    /* 1. Importamos solo los pesos necesarios de Bricolage para optimizar carga */
    @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600..800&display=swap');
    
    /* Importamos Inter para el cuerpo (opcional, si prefieres Inter sobre system-ui) */
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap');

    :root {
        --font-title: 'Bricolage Grotesque', sans-serif;
        --font-body: 'Inter', system-ui, -apple-system, sans-serif;
    }

    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        background: #000000;
        color: white;
        /* Fuente por defecto para párrafos y botones */
        font-family: var(--font-body); 
        line-height: 1.6;
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
    }

    /* 2. Aplicamos Bricolage EXCLUSIVAMENTE a los títulos */
    h1, h2, h3, h4, .font-title {
        font-family: var(--font-title);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 0.95;
        color: #ffffff;
    }

    /* Ajuste para párrafos: menos peso, más aire */
    p {
        font-family: var(--font-body);
        font-weight: 300; /* Peso ligero para look premium */
        color: rgba(255, 255, 255, 0.7); /* Gris suave para jerarquía visual */
    }

    .page-container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }
</style>